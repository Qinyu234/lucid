{
  "id": "parse_text",
  "version": "1.0.0",
  "schema_version": "1.0.0",
  "kind": "functional",
  "description": "Parse text string into list of tokens",
  "inputs": {
    "text": {
      "schema": {
        "shape": "string"
      },
      "required": true
    }
  },
  "outputs": {
    "tokens": {
      "schema": {
        "shape": "list",
        "items": {
          "shape": "string"
        }
      },
      "required": true
    }
  },
  "implementations": {
    "python": {
      "code_file": "implementations/python/code.py",
      "deps": []
    }
  },
  "tests": {
    "fixed_cases": [
      {
        "name": "happy_path",
        "inputs": {
          "text": "hello world"
        },
        "expect": {
          "outputs": {
            "tokens": ["hello", "world"]
          }
        }
      },
      {
        "name": "boundary_empty",
        "inputs": {
          "text": ""
        },
        "expect": {
          "outputs": {
            "tokens": []
          }
        }
      }
    ],
    "generated_rules": {
      "boundary": true,
      "null_input": true,
      "type_error": true,
      "missing_port": true
    }
  },
  "tags": ["text_processing", "tokenization"]
}
