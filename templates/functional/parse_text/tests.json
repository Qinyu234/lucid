{
  "fixed_cases": [
    {
      "name": "happy_path",
      "inputs": {
        "text": "hello world"
      },
      "expect": {
        "outputs": {
          "tokens": ["hello", "world"]
        }
      }
    },
    {
      "name": "boundary_empty",
      "inputs": {
        "text": ""
      },
      "expect": {
        "outputs": {
          "tokens": []
        }
      }
    },
    {
      "name": "boundary_single_word",
      "inputs": {
        "text": "hello"
      },
      "expect": {
        "outputs": {
          "tokens": ["hello"]
        }
      }
    }
  ],
  "generated_rules": {
    "boundary": true,
    "null_input": true,
    "type_error": true,
    "missing_port": true
  }
}
