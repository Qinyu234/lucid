{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "io.schema.json",
  "version": "1.0.0",
  "description": "Port definitions and coerce rules. All edge compatibility is decided here.",

  "definitions": {

    "port": {
      "type": "object",
      "required": ["id", "schema"],
      "properties": {
        "id":          { "$ref": "primitives.schema.json#/definitions/identifier" },
        "schema":      { "$ref": "primitives.schema.json#/definitions/port_schema" },
        "required":    { "type": "boolean", "default": true },
        "default":     { "description": "Used if port not connected and required=false" },
        "description": { "type": "string" }
      },
      "additionalProperties": false
    },

    "port_set": {
      "description": "Named collection of ports (inputs or outputs of a node)",
      "type": "object",
      "additionalProperties": { "$ref": "#/definitions/port" }
    },

    "edge_compatibility": {
      "description": "Result of checking if two ports can be connected",
      "type": "object",
      "required": ["allowed", "safety"],
      "properties": {
        "allowed":     { "type": "boolean" },
        "safety":      { "$ref": "primitives.schema.json#/definitions/coerce_safety" },
        "coerce_fn":   { "type": "string", "description": "Name of registered coerce function, if any" },
        "reason":      { "type": "string", "description": "Why forbidden, if applicable" }
      },
      "additionalProperties": false
    }

  },

  "coerce_table": {
    "description": "shape × shape → safety. Rows=from, Cols=to.",
    "version": "1.0.0",
    "note": "Extend by registering in type_registry.json, do not edit this table directly.",

    "string": {
      "string": "safe",
      "number": "unsafe",
      "bool":   "unsafe",
      "bytes":  "safe",
      "list":   "forbidden",
      "dict":   "unsafe",
      "null":   "forbidden",
      "enum":   "unsafe"
    },
    "number": {
      "string": "safe",
      "number": "safe",
      "bool":   "safe",
      "bytes":  "forbidden",
      "list":   "forbidden",
      "dict":   "forbidden",
      "null":   "forbidden",
      "enum":   "forbidden"
    },
    "bool": {
      "string": "safe",
      "number": "safe",
      "bool":   "safe",
      "bytes":  "forbidden",
      "list":   "forbidden",
      "dict":   "forbidden",
      "null":   "forbidden",
      "enum":   "forbidden"
    },
    "bytes": {
      "string": "unsafe",
      "number": "forbidden",
      "bool":   "forbidden",
      "bytes":  "safe",
      "list":   "forbidden",
      "dict":   "forbidden",
      "null":   "forbidden",
      "enum":   "forbidden"
    },
    "list": {
      "string": "unsafe",
      "number": "forbidden",
      "bool":   "forbidden",
      "bytes":  "forbidden",
      "list":   "safe",
      "dict":   "forbidden",
      "null":   "forbidden",
      "enum":   "forbidden"
    },
    "dict": {
      "string": "safe",
      "number": "forbidden",
      "bool":   "forbidden",
      "bytes":  "forbidden",
      "list":   "forbidden",
      "dict":   "safe",
      "null":   "forbidden",
      "enum":   "forbidden"
    },
    "null": {
      "string":   "forbidden",
      "number":   "forbidden",
      "bool":     "forbidden",
      "bytes":    "forbidden",
      "list":     "forbidden",
      "dict":     "forbidden",
      "null":     "safe",
      "enum":     "forbidden"
    },
    "enum": {
      "string": "safe",
      "number": "forbidden",
      "bool":   "forbidden",
      "bytes":  "forbidden",
      "list":   "forbidden",
      "dict":   "forbidden",
      "null":   "forbidden",
      "enum":   "unsafe"
    }
  }
}
