{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "graph.schema.json",
  "version": "1.0.0",
  "description": "Graph L1: the logical source of truth. L2 (physical) is compiler-internal and never persisted.",

  "type": "object",
  "required": ["id", "version", "schema_version", "root_id", "nodes", "edges"],

  "properties": {

    "id":             { "$ref": "primitives.schema.json#/definitions/identifier" },
    "version":        { "$ref": "primitives.schema.json#/definitions/semver" },
    "schema_version": { "$ref": "primitives.schema.json#/definitions/semver",
                        "description": "Version of graph.schema.json this file was written against" },
    "name":           { "type": "string" },
    "description":    { "type": "string" },
    "created_at":     { "$ref": "primitives.schema.json#/definitions/timestamp" },
    "updated_at":     { "$ref": "primitives.schema.json#/definitions/timestamp" },

    "root_id": {
      "description": "Id of the single root node. Must be a control node.",
      "$ref": "primitives.schema.json#/definitions/identifier"
    },

    "nodes": {
      "type": "object",
      "description": "Map of node_id → node. Flat, no nesting.",
      "additionalProperties": { "$ref": "node.schema.json#/definitions/node" }
    },

    "edges": {
      "type": "object",
      "description": "Map of edge_id → edge",
      "additionalProperties": { "$ref": "node.schema.json#/definitions/edge" }
    },

    "metadata": {
      "type": "object",
      "description": "Arbitrary key-value for editor state, tags, etc. Not used by compiler.",
      "additionalProperties": true
    }

  },

  "additionalProperties": false
}
