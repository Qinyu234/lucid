{
  "name": "lucid-code-observatory",
  "displayName": "Lucid Code Observatory",
  "description": "Code analysis tool for understanding code structure, access patterns, and dependencies",
  "version": "0.1.0",
  "publisher": "lucid",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:lucidStructureView",
    "onView:lucidDefUseView",
    "onCommand:lucid.analyzeFile",
    "onCommand:lucid.analyzeWorkspace"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "lucid",
          "title": "Lucid",
          "icon": "assets/lucid-icon.svg"
        }
      ]
    },
    "views": {
      "lucid": [
        {
          "id": "lucidStructureView",
          "name": "Structure"
        },
        {
          "id": "lucidDefUseView",
          "name": "Def-Use Contracts"
        }
      ]
    },
    "commands": [
      {
        "command": "lucid.analyzeFile",
        "title": "Analyze Current File",
        "icon": "$(search)"
      },
      {
        "command": "lucid.analyzeWorkspace",
        "title": "Analyze Workspace",
        "icon": "$(database)"
      },
      {
        "command": "lucid.showImpact",
        "title": "Show Impact Analysis",
        "icon": "$(beaker)"
      },
      {
        "command": "lucid.checkContracts",
        "title": "Check Access Contracts",
        "icon": "$(check)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "lucid.analyzeFile",
          "when": "editorLangId == python || editorLangId == javascript || editorLangId == typescript",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "command": "lucid.analyzeFile",
          "when": "resourceLangId == python || resourceLangId == javascript || resourceLangId == typescript",
          "group": "lucid"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/vscode": "^1.75.0",
    "@types/node": "^18.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "cytoscape": "^3.23.0"
  }
}
