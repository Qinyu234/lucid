{
  "id": "branch_test",
  "version": "1.0.0",
  "schema_version": "1.0.0",
  "name": "Branch Test",
  "description": "Test BRANCH control node with condition=true routing to parse_text",
  "root_id": "root_seq",
  "nodes": {
    "root_seq": {
      "id": "root_seq",
      "type": "control",
      "kind": "SEQ",
      "inputs": {},
      "outputs": {},
      "children": ["node_input", "node_branch", "node_save"]
    },
    "node_input": {
      "id": "node_input",
      "type": "functional",
      "template_id": "input",
      "template_version": "1.0.0",
      "inputs": {},
      "outputs": {
        "text": { "id": "text", "schema": { "shape": "string" } },
        "condition": { "id": "condition", "schema": { "shape": "bool" } }
      },
      "params": {
        "text": "hello world",
        "condition": true
      }
    },
    "node_branch": {
      "id": "node_branch",
      "type": "control",
      "kind": "BRANCH",
      "inputs": {
        "condition": { "id": "condition", "schema": { "shape": "bool" }, "required": true },
        "value": { "id": "value", "schema": { "shape": "string" }, "required": false }
      },
      "outputs": {
        "result": { "id": "result", "schema": { "shape": "union", "variants": ["string","number","bool","list","dict","null"] }, "required": true }
      },
      "condition_port": "condition",
      "true_branch": "node_parse",
      "false_branch": null
    },
    "node_parse": {
      "id": "node_parse",
      "type": "functional",
      "template_id": "parse_text",
      "template_version": "1.0.0",
      "inputs": {
        "text": { "id": "text", "schema": { "shape": "string" }, "required": true },
        "separator": { "id": "separator", "schema": { "shape": "string" }, "required": false }
      },
      "outputs": {
        "tokens": { "id": "tokens", "schema": { "shape": "list", "items": { "shape": "string" } }, "required": true }
      },
      "params": {
        "separator": " "
      }
    },
    "node_save": {
      "id": "node_save",
      "type": "functional",
      "template_id": "save_json",
      "template_version": "1.0.0",
      "inputs": {
        "data": { "id": "data", "schema": { "shape": "dict" }, "required": true },
        "path": { "id": "path", "schema": { "shape": "string" }, "required": true }
      },
      "outputs": {
        "success": { "id": "success", "schema": { "shape": "bool" }, "required": true },
        "path": { "id": "path", "schema": { "shape": "string" }, "required": true }
      },
      "params": {
        "path": "io/output/branch_result.json"
      }
    }
  },
  "edges": {
    "e1": {
      "id": "e1",
      "from_node": "node_input",
      "from_port": "text",
      "to_node": "node_branch",
      "to_port": "value"
    },
    "e2": {
      "id": "e2",
      "from_node": "node_input",
      "from_port": "condition",
      "to_node": "node_branch",
      "to_port": "condition"
    },
    "e3": {
      "id": "e3",
      "from_node": "node_branch",
      "from_port": "result",
      "to_node": "node_save",
      "to_port": "data"
    }
  }
}
