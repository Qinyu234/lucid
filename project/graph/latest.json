{
  "id": "first_graph",
  "version": "1.0.0",
  "schema_version": "1.0.0",
  "name": "First Graph",
  "description": "Read text, parse into tokens, save as JSON",
  "root_id": "root_seq",
  "nodes": {
    "root_seq": {
      "id": "root_seq",
      "type": "control",
      "kind": "SEQ",
      "inputs": {},
      "outputs": {},
      "children": ["node_input", "node_parse", "node_save"]
    },
    "node_input": {
      "id": "node_input",
      "type": "functional",
      "template_id": "input",
      "template_version": "1.0.0",
      "inputs": {},
      "outputs": {
        "text": {
          "id": "text",
          "schema": { "shape": "string" }
        }
      },
      "params": {
        "value": "hello world foo bar",
        "port": "text"
      }
    },
    "node_parse": {
      "id": "node_parse",
      "type": "functional",
      "template_id": "parse_text",
      "template_version": "1.0.0",
      "inputs": {
        "text": { "id": "text", "schema": { "shape": "string" }, "required": true },
        "separator": { "id": "separator", "schema": { "shape": "string" }, "required": false }
      },
      "outputs": {
        "tokens": { "id": "tokens", "schema": { "shape": "list", "items": { "shape": "string" } }, "required": true }
      }
    },
    "node_save": {
      "id": "node_save",
      "type": "functional",
      "template_id": "save_json",
      "template_version": "1.0.0",
      "inputs": {
        "data": { "id": "data", "schema": { "shape": "dict" }, "required": true },
        "path": { "id": "path", "schema": { "shape": "string" }, "required": true }
      },
      "outputs": {
        "success": { "id": "success", "schema": { "shape": "bool" }, "required": true },
        "path": { "id": "path", "schema": { "shape": "string" }, "required": true }
      },
      "params": {
        "path": "io/output/result.json"
      }
    }
  },
  "edges": {
    "e1": {
      "id": "e1",
      "from_node": "node_input",
      "from_port": "text",
      "to_node": "node_parse",
      "to_port": "text"
    },
    "e2": {
      "id": "e2",
      "from_node": "node_parse",
      "from_port": "tokens",
      "to_node": "node_save",
      "to_port": "data"
    }
  },
  "edge_transforms": {
    "e2": {
      "wrap": {"key": "tokens"}
    }
  }
}
