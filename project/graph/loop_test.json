{
  "id": "loop_test",
  "version": "1.0.0",
  "schema_version": "1.0.0",
  "name": "Loop Test",
  "description": "Test LOOP control node with parse_text body",
  "root_id": "root_seq",
  "nodes": {
    "root_seq": {
      "id": "root_seq",
      "type": "control",
      "kind": "SEQ",
      "inputs": {},
      "outputs": {},
      "children": ["node_input", "node_loop", "node_save"]
    },
    "node_input": {
      "id": "node_input",
      "type": "functional",
      "template_id": "input",
      "template_version": "1.0.0",
      "inputs": {},
      "outputs": {
        "items": { "id": "items", "schema": { "shape": "list" } },
        "initial_accumulator": { "id": "initial_accumulator", "schema": { "shape": "list" } }
      },
      "params": {
        "items": ["hello world", "foo bar", "baz"],
        "initial_accumulator": []
      }
    },
    "node_loop": {
      "id": "node_loop",
      "type": "control",
      "kind": "LOOP",
      "inputs": {
        "items": { "id": "items", "schema": { "shape": "list" }, "required": true },
        "initial_accumulator": { "id": "initial_accumulator", "schema": { "shape": "union" }, "required": false }
      },
      "outputs": {
        "accumulator": { "id": "accumulator", "schema": { "shape": "union" }, "required": true },
        "results": { "id": "results", "schema": { "shape": "list" }, "required": true }
      },
      "iterator_port": "items",
      "body": "node_parse",
      "accumulator_port": "accumulator"
    },
    "node_parse": {
      "id": "node_parse",
      "type": "functional",
      "template_id": "append_tokens",
      "template_version": "1.0.0",
      "inputs": {
        "item": { "id": "item", "schema": { "shape": "string" }, "required": true },
        "accumulator": { "id": "accumulator", "schema": { "shape": "list" }, "required": true }
      },
      "outputs": {
        "tokens": { "id": "tokens", "schema": { "shape": "list", "items": { "shape": "string" } }, "required": true },
        "accumulator": { "id": "accumulator", "schema": { "shape": "list" }, "required": true }
      }
    },
    "node_save": {
      "id": "node_save",
      "type": "functional",
      "template_id": "save_json",
      "template_version": "1.0.0",
      "inputs": {
        "data": { "id": "data", "schema": { "shape": "dict" }, "required": true },
        "path": { "id": "path", "schema": { "shape": "string" }, "required": true }
      },
      "outputs": {
        "success": { "id": "success", "schema": { "shape": "bool" }, "required": true },
        "path": { "id": "path", "schema": { "shape": "string" }, "required": true }
      },
      "params": {
        "path": "io/output/loop_result.json"
      }
    }
  },
  "edges": {
    "e1": {
      "id": "e1",
      "from_node": "node_input",
      "from_port": "items",
      "to_node": "node_loop",
      "to_port": "items"
    },
    "e2": {
      "id": "e2",
      "from_node": "node_input",
      "from_port": "initial_accumulator",
      "to_node": "node_loop",
      "to_port": "initial_accumulator"
    },
    "e3": {
      "id": "e3",
      "from_node": "node_loop",
      "from_port": "accumulator",
      "to_node": "node_save",
      "to_port": "data"
    }
  }
}
