{
  "id": "loop",
  "version": "1.0.0",
  "schema_version": "1.0.0",
  "name": "Loop",
  "description": "Iterate over a list, executing body for each item. Accumulator carries state between iterations.",
  "tags": ["control", "loop", "iterate"],
  "inputs": {
    "items": {
      "id": "items",
      "schema": { "shape": "list", "items": { "shape": "union", "variants": ["string","number","bool","dict","null"] } },
      "required": true,
      "description": "List to iterate over"
    },
    "initial_accumulator": {
      "id": "initial_accumulator",
      "schema": { "shape": "union", "variants": ["string","number","bool","list","dict","null"] },
      "required": false,
      "default": null,
      "description": "Starting value of accumulator"
    }
  },
  "outputs": {
    "accumulator": {
      "id": "accumulator",
      "schema": { "shape": "union", "variants": ["string","number","bool","list","dict","null"] },
      "required": true,
      "description": "Final accumulator value after all iterations"
    },
    "results": {
      "id": "results",
      "schema": { "shape": "list", "items": { "shape": "union", "variants": ["string","number","bool","dict","null"] } },
      "required": true,
      "description": "List of each iteration's output"
    }
  },
  "implementations": {
    "python": { "code_file": "implementations/python/code.py" }
  },
  "tests": {
    "fixed_cases": [
      {
        "id": "happy_path_sum",
        "description": "sum a list of numbers via accumulator",
        "inputs": { "items": [1, 2, 3], "initial_accumulator": 0 },
        "expect": {
          "outputs": { "accumulator": 6, "results": [1, 3, 6] }
        },
        "tags": ["happy_path"]
      },
      {
        "id": "happy_path_empty",
        "description": "empty list returns initial accumulator",
        "inputs": { "items": [], "initial_accumulator": 0 },
        "expect": { "outputs": { "accumulator": 0, "results": [] } },
        "tags": ["boundary"]
      },
      {
        "id": "null_items",
        "description": "null items should error",
        "inputs": { "items": null, "initial_accumulator": 0 },
        "expect": { "error": true },
        "tags": ["null_input"]
      }
    ],
    "generated_rules": {
      "boundary": true,
      "null_input": true,
      "type_error": true,
      "missing_port": true,
      "overflow": false
    }
  }
}
