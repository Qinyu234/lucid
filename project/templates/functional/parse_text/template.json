{
  "id": "parse_text",
  "version": "1.0.0",
  "schema_version": "1.0.0",
  "name": "Parse Text",
  "description": "Split a text string into a list of tokens by separator",
  "tags": ["text", "split", "tokenize"],
  "inputs": {
    "text": {
      "id": "text",
      "schema": { "shape": "string" },
      "required": true,
      "description": "Input text to split"
    },
    "separator": {
      "id": "separator",
      "schema": { "shape": "string" },
      "required": false,
      "default": " ",
      "description": "Separator string, default is space"
    }
  },
  "outputs": {
    "tokens": {
      "id": "tokens",
      "schema": { "shape": "list", "items": { "shape": "string" } },
      "required": true,
      "description": "List of tokens"
    }
  },
  "implementations": {
    "python": { "code_file": "implementations/python/code.py" }
  },
  "tests": {
    "fixed_cases": [
      {
        "id": "happy_path_basic",
        "description": "basic split by space",
        "inputs": { "text": "hello world", "separator": " " },
        "expect": { "outputs": { "tokens": ["hello", "world"] } },
        "tags": ["happy_path"]
      },
      {
        "id": "happy_path_empty",
        "description": "empty string returns empty list",
        "inputs": { "text": "", "separator": " " },
        "expect": { "outputs": { "tokens": [] } },
        "tags": ["boundary"]
      },
      {
        "id": "null_input",
        "description": "null text should error",
        "inputs": { "text": null, "separator": " " },
        "expect": { "error": true },
        "tags": ["null_input"]
      },
      {
        "id": "type_error",
        "description": "number input should error",
        "inputs": { "text": 123, "separator": " " },
        "expect": { "error": true },
        "tags": ["type_error"]
      }
    ],
    "generated_rules": {
      "boundary": true,
      "null_input": true,
      "type_error": true,
      "missing_port": true,
      "overflow": false
    }
  }
}
