{
  "id": "input",
  "version": "1.0.0",
  "schema_version": "1.0.0",
  "name": "Input",
  "description": "Graph entry point. Provides a value from params into the graph.",
  "tags": ["io", "input", "source"],
  "inputs": {},
  "outputs": {
    "value": {
      "id": "value",
      "schema": { "shape": "union", "variants": ["string","number","bool","list","dict","null"] },
      "required": true,
      "description": "The value provided by the user via params"
    }
  },
  "implementations": {
    "python": { "code_file": "implementations/python/code.py" }
  },
  "tests": {
    "fixed_cases": [
      {
        "id": "happy_path_string",
        "description": "provide a string value",
        "inputs": {},
        "expect": { "outputs": { "value": "hello" } },
        "tags": ["happy_path"]
      }
    ],
    "generated_rules": {
      "boundary": false,
      "null_input": false,
      "type_error": false,
      "missing_port": false,
      "overflow": false
    }
  }
}
