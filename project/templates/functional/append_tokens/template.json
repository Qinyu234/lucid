{
  "id": "append_tokens",
  "version": "1.0.0",
  "schema_version": "1.0.0",
  "name": "Append Tokens",
  "description": "Split text into tokens and append to accumulator",
  "tags": ["text", "split", "accumulator"],
  "inputs": {
    "item": {
      "id": "item",
      "schema": { "shape": "string" },
      "required": true,
      "description": "Text to split"
    },
    "accumulator": {
      "id": "accumulator",
      "schema": { "shape": "list" },
      "required": true,
      "description": "Accumulator list to append to"
    }
  },
  "outputs": {
    "tokens": {
      "id": "tokens",
      "schema": { "shape": "list", "items": { "shape": "string" } },
      "required": true,
      "description": "Split tokens"
    },
    "accumulator": {
      "id": "accumulator",
      "schema": { "shape": "list" },
      "required": true,
      "description": "Updated accumulator with tokens appended"
    }
  },
  "implementations": {
    "python": { "code_file": "implementations/python/code.py" }
  },
  "tests": {
    "fixed_cases": [
      {
        "id": "happy_path",
        "description": "split and append",
        "inputs": { "item": "hello world", "accumulator": ["old"] },
        "expect": { "outputs": { "tokens": ["hello", "world"], "accumulator": ["old", ["hello", "world"]] } },
        "tags": ["happy_path"]
      }
    ],
    "generated_rules": {
      "boundary": false,
      "null_input": true,
      "type_error": true,
      "missing_port": true,
      "overflow": false
    }
  }
}
