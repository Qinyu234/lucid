{
  "version": "1.0.0",
  "operations": [
    {
      "id": "text_split",
      "name": "切割文字",
      "category": "文字",
      "description": "按分隔符切割文字，返回列表",
      "input_shapes": ["string", "string"],
      "input_labels": ["文字", "分隔符"],
      "output_shape": "list",
      "expression": "a.split(b)"
    },
    {
      "id": "text_join",
      "name": "合并文字",
      "category": "文字",
      "description": "用分隔符合并列表，返回文字",
      "input_shapes": ["list", "string"],
      "input_labels": ["列表", "分隔符"],
      "output_shape": "string",
      "expression": "b.join(a)"
    },
    {
      "id": "text_length",
      "name": "文字长度",
      "category": "文字",
      "description": "返回文字的字符数",
      "input_shapes": ["string"],
      "input_labels": ["文字"],
      "output_shape": "number",
      "expression": "len(a)"
    },
    {
      "id": "text_strip",
      "name": "去除空白",
      "category": "文字",
      "description": "去除文字两端空白字符",
      "input_shapes": ["string"],
      "input_labels": ["文字"],
      "output_shape": "string",
      "expression": "a.strip()"
    },
    {
      "id": "text_replace",
      "name": "替换文字",
      "category": "文字",
      "description": "把文字里的 A 替换成 B",
      "input_shapes": ["string", "string", "string"],
      "input_labels": ["文字", "查找", "替换为"],
      "output_shape": "string",
      "expression": "a.replace(b, c)"
    },
    {
      "id": "text_contains",
      "name": "包含文字",
      "category": "文字",
      "description": "判断文字是否包含某个子串",
      "input_shapes": ["string", "string"],
      "input_labels": ["文字", "子串"],
      "output_shape": "bool",
      "expression": "b in a"
    },
    {
      "id": "num_add",
      "name": "加",
      "category": "数字",
      "input_shapes": ["number", "number"],
      "input_labels": ["A", "B"],
      "output_shape": "number",
      "expression": "a + b"
    },
    {
      "id": "num_subtract",
      "name": "减",
      "category": "数字",
      "input_shapes": ["number", "number"],
      "input_labels": ["A", "B"],
      "output_shape": "number",
      "expression": "a - b"
    },
    {
      "id": "num_multiply",
      "name": "乘",
      "category": "数字",
      "input_shapes": ["number", "number"],
      "input_labels": ["A", "B"],
      "output_shape": "number",
      "expression": "a * b"
    },
    {
      "id": "num_divide",
      "name": "除",
      "category": "数字",
      "input_shapes": ["number", "number"],
      "input_labels": ["A", "B"],
      "output_shape": "number",
      "expression": "a / b"
    },
    {
      "id": "num_greater",
      "name": "大于",
      "category": "数字",
      "input_shapes": ["number", "number"],
      "input_labels": ["A", "B"],
      "output_shape": "bool",
      "expression": "a > b"
    },
    {
      "id": "num_equal",
      "name": "等于",
      "category": "数字",
      "input_shapes": ["number", "number"],
      "input_labels": ["A", "B"],
      "output_shape": "bool",
      "expression": "a == b"
    },
    {
      "id": "list_length",
      "name": "列表长度",
      "category": "列表",
      "input_shapes": ["list"],
      "input_labels": ["列表"],
      "output_shape": "number",
      "expression": "len(a)"
    },
    {
      "id": "list_get",
      "name": "取第N个",
      "category": "列表",
      "input_shapes": ["list", "number"],
      "input_labels": ["列表", "位置（从0开始）"],
      "output_shape": "union",
      "expression": "a[int(b)]"
    },
    {
      "id": "list_append",
      "name": "追加元素",
      "category": "列表",
      "input_shapes": ["list", "union"],
      "input_labels": ["列表", "元素"],
      "output_shape": "list",
      "expression": "a + [b]"
    },
    {
      "id": "list_filter_nonempty",
      "name": "过滤空值",
      "category": "列表",
      "input_shapes": ["list"],
      "input_labels": ["列表"],
      "output_shape": "list",
      "expression": "[x for x in a if x is not None and x != '' and x != []]"
    },
    {
      "id": "logic_and",
      "name": "且",
      "category": "逻辑",
      "input_shapes": ["bool", "bool"],
      "input_labels": ["A", "B"],
      "output_shape": "bool",
      "expression": "a and b"
    },
    {
      "id": "logic_or",
      "name": "或",
      "category": "逻辑",
      "input_shapes": ["bool", "bool"],
      "input_labels": ["A", "B"],
      "output_shape": "bool",
      "expression": "a or b"
    },
    {
      "id": "logic_not",
      "name": "非",
      "category": "逻辑",
      "input_shapes": ["bool"],
      "input_labels": ["A"],
      "output_shape": "bool",
      "expression": "not a"
    }
  ]
}
